TRANSPORT_TYPE=http
PUBLIC_BASE_URL=https://mcp.example.com
CONCRETE_CANONICAL_URL=https://cms.example.com
CONCRETE_API_CLIENT_ID=YOUR_API_CLIENT_ID
CONCRETE_API_CLIENT_SECRET=YOUR_API_CLIENT_SECRET
CONCRETE_API_SCOPE=account:read system:info:read
HTTP_PORT=3000

# Required for http mode — generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# Required for http mode — shared dashboard key (dynamic user_id via header)
MCP_API_KEY=

# Optional alternative: per-key user binding (null = require X-Concrete-User-Id header)
# MCP_API_KEYS={"personal-desktop-key":42,"dashboard-backend-key":null}

# Optional: token storage directory (default: ~/.concretecms-mcp/tokens)
# TOKEN_DIR=/var/lib/concretecms-mcp/tokens

# Optional: use when hosting on the same domain as Concrete CMS
# PATH_PREFIX=/ccm-mcp
